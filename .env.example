# Gemini API
GEMINI_API_KEY=your-gemini-api-key-here

# Database
DATABASE_URL=sqlite+aiosqlite:///./ryosyusyo.db

# Upload settings
MAX_VIDEO_SIZE_MB=500
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs

# OCR settings (tesseract path for Windows)
TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
